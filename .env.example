# 复制此文件为 .env.production 并填入真实值
# cp .env.example .env.production

# Next.js
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=your-nextauth-secret

# 数据库
DB_HOST=localhost
DB_USER=ecs-user
DB_PASSWORD=your-db-password
